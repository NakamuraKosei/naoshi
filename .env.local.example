# Supabase（プロジェクト作成後に値を埋めること）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API
# 変換エンジン（/api/humanize）で使用。Claude Sonnet 4 を呼び出す。
# 未設定の場合 /api/humanize は 500 を返す。
ANTHROPIC_API_KEY=
# MOCK_HUMANIZE=1 にすると Anthropic を呼ばずにダミー応答を返す（開発時のフロー確認用）
MOCK_HUMANIZE=

# Stripe（M3フェーズで設定）
# Stripe ダッシュボードから取得する秘密鍵（サーバーのみ）
STRIPE_SECRET_KEY=
# Stripe CLI でローカルテストする場合は `stripe listen` の出力を設定
STRIPE_WEBHOOK_SECRET=
# 将来的にクライアントから Stripe.js を使う場合に備えて
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe 価格 ID（requirements.md 第7章のプランに対応）
# ライト（週 ¥500）
STRIPE_PRICE_LIGHT_WEEKLY=
# ヘビー（月 ¥2,980）
STRIPE_PRICE_HEAVY_MONTHLY=
# ヘビー（年 ¥24,000）
STRIPE_PRICE_HEAVY_YEARLY=
